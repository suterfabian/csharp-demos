<Window x:Class="HeyAsync.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Async WPF Lab"
        Width="1200"
        Height="750"
        MinWidth="900"
        MinHeight="600"
        Background="#0F172A"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="76" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#111827"
                BorderBrush="#1F2937"
                BorderThickness="0 0 0 1">
            <Grid Margin="28 0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Async WPF Lab"
                               Foreground="#F9FAFB"
                               FontSize="26"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Tests für async/await, Dispatcher, Locks und parallele Abläufe"
                               Foreground="#94A3B8"
                               FontSize="13"
                               Margin="0 4 0 0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Layout -->
        <Grid Grid.Row="1" Margin="22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Aside -->
            <Border Grid.Column="0"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="18">

                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Tests"
                               Foreground="#F9FAFB"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0 0 0 18" />

                    <ScrollViewer Style="{StaticResource AsideScrollViewerStyle}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <Button Content="01 - Basic async/await"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="BasicAsyncButton_Click" />

                            <Button Content="02 - Task.Run"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="TaskRunButton_Click" />

                            <Button Content="03 - Dispatcher"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="DispatcherButton_Click" />

                            <Button Content="04 - Race Condition"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="RaceConditionButton_Click" />

                            <Button Content="05 - Lock"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="LockButton_Click" />

                            <Button Content="06 - Interlocked"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="InterlockedButton_Click" />

                            <Button Content="07 - Parallel Object List"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="ParallelObjectListButton_Click" />

                            <Button Content="08 - ConcurrentBag"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="ConcurrentBagButton_Click" />

                            <Button Content="09 - Fehler in Tasks"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="TaskErrorButton_Click" />
                            
                            <Button Content="10 - CancellationToken"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="CancellationButton_Click"/>
                            
                            <Button Content="11 - Deadlock"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="DeadlockButton_Click"/>
                            
                            <Button Content="12 - NoDeadlock"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="NoDeadlockButton_Click"/>
                            
                            <Button Content="13 - Deadlock Übung"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="DeadlockExerciseButton_Click"/>

                            <Button Content="14 - SemaphoreSlim"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="SemaphoreSlimButton_Click"/>

                            <Button Content="15 - Channel Producer/Consumer"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="ChannelButton_Click"/>
                            
                            <Button Content="16 - Async Stream"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="AsyncStreamButton_Click"/>
                            
                            <Button Content="17 - Progress Reporting"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="ProgressButton_Click"/>
                            
                            <Button Content="18 - WhenAll / WhenAny"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="WhenAllButton_Click"/>
                            
                            <Button Content="19 - Task.WhenAny"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="WhenAnyButton_Click"/>
                            
                            <Button Content="20 - WhenAll Exceptions"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="WhenAllExceptionButton_Click"/>
                            
                            <Button Content="21 - Cancellation + WhenAll"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="CancellationWhenAllButton_Click"/>
                            
                            <Button Content="22 - TaskCompletionSource"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="TaskCompletionSourceButton_Click"/>
                            
                            <Button Content="23 - TCS Fehlerfall"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="TaskCompletionSourceErrorButton_Click"/>
                            
                            <Button Content="24 - BLE Request / Response"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="BleRequestResponseButton_Click"/>
                            
                            <Button Content="25 - BLE Timeout"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="BleTimeoutButton_Click"/>
                            
                            <Button Content="26 - BLE Retry"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="BleRetryButton_Click"/>
                            
                            <Button Content="27 - Retry mit Fehlern"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="BleRetryErrorButton_Click"/>
                            
                            <Button Content="28 - BLE Command Queue"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="BleCommandQueueButton_Click"/>
                            
                            <Button Content="29 - Firmware Upload"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="FirmwareUploadButton_Click"/>
                            
                            <Button Content="30 - Firmware Upload Cancel"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="FirmwareUploadWithCancelButton_Click"/>
                            
                            <Button Content="31 - Firmware Upload Retry"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="FirmwareUploadRetryButton_Click"/>
                            
                            <Button Content="32 - Firmware Upload Transient Retry"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="FirmwareUploadTransientRetryButton_Click"/>
                            
                            
                            
                            
                            
                            
                            <Button Content="Firmware Upload abbrechen"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Click="CancelFirmwareUploadButton_Click"/>
                            
                            <Button Content="BLE Vorgang abbrechen"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Click="CancelBleTimeoutButton_Click"/>
                            
                            <Button Content="Abbrechen"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Click="CancelButton_Click"/>

                            <Button Content="Ausgabe leeren"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Click="ClearButton_Click" />
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Content -->
            <Border Grid.Column="2"
                    Background="#020617"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="18">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Ausgabe"
                               Foreground="#F9FAFB"
                               FontSize="18"
                               FontWeight="SemiBold" />

                    <TextBox x:Name="OutputTextBox"
                             Grid.Row="2"
                             Style="{StaticResource OutputTextBoxStyle}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>