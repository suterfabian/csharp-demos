<Window x:Class="HeyAsync.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Async WPF Lab"
        Width="1200"
        Height="750"
        MinWidth="900"
        MinHeight="600"
        Background="#0F172A"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="76" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#111827"
                BorderBrush="#1F2937"
                BorderThickness="0 0 0 1">
            <Grid Margin="28 0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Async WPF Lab"
                               Foreground="#F9FAFB"
                               FontSize="26"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Tests für async/await, Dispatcher, Locks und parallele Abläufe"
                               Foreground="#94A3B8"
                               FontSize="13"
                               Margin="0 4 0 0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Layout -->
        <Grid Grid.Row="1" Margin="22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Aside -->
            <Border Grid.Column="0"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="18">

                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Tests"
                               Foreground="#F9FAFB"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0 0 0 18" />

                    <ScrollViewer Style="{StaticResource AsideScrollViewerStyle}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding DemoButtons}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Title}"
                                                Command="{Binding Command}"
                                                Style="{StaticResource MenuButtonStyle}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Content="Abbrechen"
                                    Command="{Binding CancelCommand}"
                                    Style="{StaticResource DangerButtonStyle}" />

                            <Button Content="Ausgabe leeren"
                                    Command="{Binding ClearCommand}"
                                    Style="{StaticResource DangerButtonStyle}" />
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Content -->
            <Border Grid.Column="2"
                    Background="#020617"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="18">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Ausgabe"
                               Foreground="#F9FAFB"
                               FontSize="18"
                               FontWeight="SemiBold" />

                    <TextBox Grid.Row="2"
                             Text="{Binding OutputText}"
                             Style="{StaticResource OutputTextBoxStyle}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>